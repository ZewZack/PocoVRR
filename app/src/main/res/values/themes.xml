<resources>
    <style name="Theme.PocoVRR" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorPrimaryVariant">#EEEEEE</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="android:windowBackground">#000000</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:colorBackground">#000000</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>

    <!-- Ayar toggle butonları için ortak stil -->
    <style name="PocoVRR.ToggleButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/toggle_button_text</item>
        <item name="backgroundTint">@color/toggle_button_bg</item>
        <item name="strokeColor">@color/toggle_button_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>
</resources>
